# Copy to .env and change all secrets before production.
# Do not commit .env to Git.

APP_NAME=School Registration System
APP_ENV=production
APP_DEBUG=false

SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
EXPOSE_OPENAPI=false
AUTO_CREATE_TABLES=false
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=15
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900

# Database (must match POSTGRES_* below; host name "postgres" = Docker service)
POSTGRES_DB=school_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+psycopg2://postgres:change_me_strong_password@postgres:5432/school_db

# Redis (Docker Compose service name: redis)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# API response cache (DB 2 — separate from Celery broker/result on 0/1)
REDIS_CACHE_ENABLED=true
REDIS_CACHE_URL=redis://redis:6379/2
REDIS_CACHE_TTL_LIST=120
REDIS_CACHE_TTL_DASHBOARD=60
REDIS_CACHE_TTL_AUTH_ME=300

USE_CELERY_TASKS=true
CELERY_BEAT_HANDLES_SCHEDULES=true

# Ports (host mapping is in docker-compose.yml)
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Telegram
TELEGRAM_BOT_TOKEN=change_me
# Numeric Telegram user/chat id allowed to use the bot (comma-separated for multiple)
TELEGRAM_CHAT_ID=123456789
TELEGRAM_WEBHOOK_SECRET=change_me
TELEGRAM_USE_POLLING=true
TELEGRAM_POLLING_ROLE=
TELEGRAM_POLLING_IN_API=false
TELEGRAM_ACTIVITY_ALERTS_ENABLED=true

# Google Sheets backup (optional)
GOOGLE_SHEETS_BACKUP_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/service-account-key.json
GOOGLE_SPREADSHEET_ID=change_me
BACKUP_TIMEZONE=Asia/Phnom_Penh
BACKUP_SCHEDULE_HOUR=19
BACKUP_SCHEDULE_MINUTE=0

# Any private LAN IP on APP_PUBLIC_PORT works when ALLOW_LAN=true (deploy on any PC)
BACKEND_CORS_ALLOW_LAN=true
APP_PUBLIC_PORT=18080
# Optional fixed origins only (leave empty for LAN-only deploy)
BACKEND_CORS_ORIGINS=
UPLOAD_DIR=/app/uploads
RUN_DB_MIGRATIONS=true

# Load balancing (Docker Compose + Nginx). See README "Load balancing".
BACKEND_REPLICAS=2
CELERY_WORKER_REPLICAS=2
UVICORN_WORKERS=2
CELERY_WORKER_CONCURRENCY=4
