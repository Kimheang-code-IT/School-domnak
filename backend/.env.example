# Local development (SQLite). For Docker/Postgres see repo root .env.example

DATABASE_URL=sqlite:///./school.db
SECRET_KEY=change-me-in-development
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

USE_CELERY_TASKS=false
CELERY_BEAT_HANDLES_SCHEDULES=false

GOOGLE_SHEETS_BACKUP_ENABLED=false
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials/google-sheets-service-account.json
GOOGLE_SPREADSHEET_ID=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_USE_POLLING=true
TELEGRAM_POLLING_IN_API=true
